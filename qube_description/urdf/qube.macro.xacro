<?xml version="1.0"?>
<robot xmlns:xacro="http://www.ros.org/wiki/xacro">

  <xacro:macro name="qube" params="prefix">

    <!-- Parameteriserte verdier for enkel justering -->
    <xacro:property name="base_size"   value="0.1"/>
    <xacro:property name="disk_radius" value="0.048"/>
    <xacro:property name="disk_length" value="0.018"/>
    <xacro:property name="cross_size"  value="0.09"/>

    <!-- Svart boks (base) -->
    <link name="${prefix}base_link">
      <visual>
        <origin xyz="0 0 ${base_size/2}"/>
        <geometry>
          <box size="${base_size} ${base_size} ${base_size}"/>
        </geometry>
        <material name="black">
          <color rgba="0.1 0.1 0.1 1"/>
        </material>
      </visual>
    </link>

    <!-- Rød disk -->
    <link name="${prefix}disk_link">
      <visual>
        <geometry>
          <cylinder radius="${disk_radius}" length="${disk_length}"/>
        </geometry>
        <material name="red">
          <color rgba="0.8 0.05 0.05 1"/>
        </material>
      </visual>
    </link>

    <!-- Hvitt kors linje 1 (horisontal) -->
    <link name="${prefix}pointer_h_link">
      <visual>
        <origin xyz="0 0 0.01"/>
        <geometry>
          <box size="${cross_size} 0.004 0.002"/>
        </geometry>
        <material name="white">
          <color rgba="1 1 1 1"/>
        </material>
      </visual>
    </link>

    <!-- Hvitt kors linje 2 (vertikal) -->
    <link name="${prefix}pointer_v_link">
      <visual>
        <origin xyz="0 0 0.01"/>
        <geometry>
          <box size="0.004 ${cross_size} 0.002"/>
        </geometry>
        <material name="white">
          <color rgba="1 1 1 1"/>
        </material>
      </visual>
    </link>

    <!-- Motorledd - disken spinner på toppen av basen -->
    <joint name="${prefix}motor_joint" type="continuous">
      <parent link="${prefix}base_link"/>
      <child link="${prefix}disk_link"/>
      <origin xyz="0 0 ${base_size + disk_length/2}"/>
      <axis xyz="0 0 1"/>
    </joint>

    <!-- Horisontal korslinje festet til disk -->
    <joint name="${prefix}pointer_h_joint" type="fixed">
      <parent link="${prefix}disk_link"/>
      <child link="${prefix}pointer_h_link"/>
      <origin xyz="0 0 0"/>
    </joint>

    <!-- Vertikal korslinje festet til disk -->
    <joint name="${prefix}pointer_v_joint" type="fixed">
      <parent link="${prefix}disk_link"/>
      <child link="${prefix}pointer_v_link"/>
      <origin xyz="0 0 0"/>
    </joint>

  </xacro:macro>

</robot>
